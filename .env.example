# App
NODE_ENV=development
PORT=3001
APP_URL=https://your-app.railway.app
SHOPIFY_APP_URL=https://your-app.railway.app

# Shopify
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_products,read_orders,read_customers,read_content,read_shipping,read_analytics,write_draft_orders
SHOPIFY_HOST=your-app.railway.app
SHOPIFY_API_VERSION=2024-01

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/voice-nimble?retryWrites=true&w=majority

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Jambonz
JAMBONZ_BASE_URL=https://your-jambonz-instance.com
JAMBONZ_API_KEY=your_jambonz_api_key
JAMBONZ_ACCOUNT_SID=your_jambonz_account_sid
JAMBONZ_WEBHOOK_SECRET=your_jambonz_webhook_secret

# AI - Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key

# Email (SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
EMAIL_FROM=noreply@voicenimble.com
EMAIL_FROM_NAME=Voice Nimble

# AWS S3 (for call recordings)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=voice-nimble-recordings

# Session
SESSION_SECRET=your-session-secret-change-this

# Webhook
WEBHOOK_SECRET=your-webhook-secret
